{
  "name": "exchekskillsvideo",
  "version": "1.1.0",
  "description": "ExChek Engine (Video) — render branded, narrated, audit-traceable compliance video summaries (.mp4) from any ExChekSkills .json sibling. Companion to exchekskills.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "exchek-video": "./scripts/report-to-video.mjs"
  },
  "scripts": {
    "render": "node scripts/report-to-video.mjs",
    "render:risk-triage": "node scripts/report-to-video.mjs fixtures/risk-triage-sample.json --template risk-triage --output renders/risk-triage-demo.mp4",
    "render:classification": "node scripts/report-to-video.mjs fixtures/classification-sample.json --template classification --output renders/classification-demo.mp4",
    "render:red-flag": "node scripts/report-to-video.mjs fixtures/red-flag-sample.json --template red-flag --output renders/red-flag-demo.mp4",
    "preview": "node scripts/report-to-video.mjs --preview",
    "lint:templates": "for d in templates/*/composition.html; do npx hyperframes lint \"$d\" || true; done",
    "test": "node tests/smoke.mjs",
    "doctor": "npx hyperframes doctor"
  },
  "dependencies": {
    "hyperframes": "latest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/exchekinc/exchekskillsvideo.git"
  },
  "keywords": [
    "exchek",
    "compliance",
    "export-control",
    "ear",
    "itar",
    "video",
    "hyperframes",
    "claude-skills"
  ],
  "author": "ExChek, Inc.",
  "license": "SEE LICENSE IN LICENSE.md"
}
